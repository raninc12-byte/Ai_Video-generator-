# ============ AI MODEL CONFIGURATION ============
# Model type: "diffusers" or "ollama"
# - diffusers: Stable Diffusion (Hugging Face) - GPU-accelerated, fast
# - ollama: Local LLM models - flexible, offline
MODEL_TYPE=diffusers

# ============ DIFFUSERS CONFIGURATION ============
# Text-to-image model to use
# Options:
#   - segmind/SSD-1B     (default, fast, ~1GB, recommended)
#   - stable-diffusion-v1-5  (~4GB)
#   - stabilityai/stable-diffusion-2  (~5GB, high quality)
TEXT_TO_IMAGE_MODEL=segmind/SSD-1B

# ============ OLLAMA CONFIGURATION ============
# Ollama server host
# Default: http://localhost:11434
OLLAMA_HOST=http://localhost:11434

# Ollama model name
# Popular options:
#   - llama2      (LLM for text generation)
#   - llava       (Vision model - can understand images)
#   - mistral     (Fast, high-quality LLM)
OLLAMA_MODEL=llama2

# Ollama request timeout in seconds
OLLAMA_TIMEOUT=300

# ============ VIDEO SETTINGS ============
VIDEO_WIDTH=1080
VIDEO_HEIGHT=1920
VIDEO_FPS=30
VIDEO_DURATION=30

# ============ PERFORMANCE SETTINGS ============
USE_GPU=True
BATCH_SIZE=1

# ============ LOGGING ============
LOG_LEVEL=INFO

# ============ DEPRECATED - TikTok Settings (no longer used) ============
# TikTok API Credentials (deprecated - project no longer uploads to TikTok)
# TIKTOK_CLIENT_KEY=your_client_key_here
# TIKTOK_CLIENT_SECRET=your_client_secret_here
# TIKTOK_ACCESS_TOKEN=your_access_token_here

# Optional: OpenAI API Key for text generation (if using GPT for prompts)
# OPENAI_API_KEY=your_openai_key_here

# Optional: Other API Keys
# HUGGINGFACE_TOKEN=your_huggingface_token_here
